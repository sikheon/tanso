# ============================================================
# E.L.O — Environment Variables (Frontend / Next.js)
# ============================================================
# Copy this file to `frontend/.env.local` and fill in your keys.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# ============================================================

# Kakao Maps JS SDK key (browser-exposed; domain-restricted)
NEXT_PUBLIC_KAKAO_MAP_KEY=your_kakao_javascript_key_here

# Backend API base URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
