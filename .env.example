# ============================================================
# E.L.O — Environment Variables (Backend)
# ============================================================
# Copy this file to `.env` and fill in your actual keys.
# DO NOT commit `.env` to git.
# ============================================================

# ----- Routing APIs -----
KAKAO_REST_API_KEY=your_kakao_rest_api_key_here
ORS_API_KEY=your_openrouteservice_api_key_here

# ----- LLM (Gemini) -----
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ----- Database -----
# Default values match docker-compose.yml
DATABASE_URL=postgresql+asyncpg://elo:elo_password@localhost:5432/elo
POSTGRES_USER=elo
POSTGRES_PASSWORD=elo_password
POSTGRES_DB=elo

# ----- Backend Server -----
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000

# ----- Logging -----
LOG_LEVEL=INFO
LOG_FORMAT=json

# ----- Feature Flags -----
ENABLE_LLM_NARRATIVE=true
ENABLE_ORS=true
LLM_FALLBACK_TO_TEMPLATE=true
